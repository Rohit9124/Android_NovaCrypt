<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Toolbar always on top -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="?attr/colorOnPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <!-- Container for your different screens -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ================= MAIN MENU ================= -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_main_menu_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?android:attr/colorBackground"
            android:visibility="visible">

            <Button
                android:id="@+id/btn_encrypt_menu_text"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="52dp"
                android:background="@drawable/rounded_button"
                android:text="@string/encrypt_text"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/btn_decrypt_menu_text"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/rounded_button"
                android:text="@string/decrypt_text"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_encrypt_menu_text" />

            <androidx.cardview.widget.CardView
                android:id="@+id/guideCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_decrypt_menu_text">

                <TextView
                    android:id="@+id/tvGuide"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:lineSpacingExtra="4dp"
                    android:padding="16dp"
                    android:text="Quick guide will appear here"
                    android:textColor="?attr/colorOnBackground"
                    android:textSize="15sp" />
            </androidx.cardview.widget.CardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ================= ENCRYPT LAYOUT ================= -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_encrypt_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?android:attr/colorBackground"
            android:padding="16dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/plain_input"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/edittext_border"
                android:gravity="top|start"
                android:hint="@string/enter_text_to_encrypt"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurface"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Key field with toggle button inside -->
            <RelativeLayout
                android:id="@+id/key_field_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/edittext_border"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/plain_input">

                <EditText
                    android:id="@+id/key_field"
                    android:layout_width="match_parent"
                    android:layout_height="47dp"
                    android:background="@null"
                    android:backgroundTint="@null"
                    android:hint="@string/encryption_key"
                    android:inputType="textPassword"
                    android:paddingStart="12dp"
                    android:paddingEnd="48dp"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOnSurface" />

                <ImageButton
                    android:id="@+id/btn_toggle_key_visibility"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle Key Visibility"
                    app:srcCompat="@drawable/baseline_visibility_off_24" />
            </RelativeLayout>


            <Button
                android:id="@+id/encrypt_text_button"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="44dp"
                android:background="@drawable/rounded_button"
                android:text="@string/encrypt"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.496"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/key_field_container" />

            <TextView
                android:id="@+id/cipher_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/cipher_text_base64"
                android:textColor="?attr/colorOnBackground"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/encrypt_text_button" />

            <TextView
                android:id="@+id/cipher_output"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_border_default"
                android:ellipsize="none"
                android:gravity="top|start"
                android:padding="12dp"
                android:scrollbars="vertical"
                android:singleLine="false"
                android:textColor="?attr/colorOnSurface"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cipher_label" />

            <LinearLayout
                android:id="@+id/actions_encrypt_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cipher_output">

                <Button
                    android:id="@+id/copy_cipher_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/copy"
                    android:textColor="?attr/colorOnSurface" />

                <Button
                    android:id="@+id/share_cipher_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/share"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ================= DECRYPT LAYOUT ================= -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_decrypt_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?android:attr/colorBackground"
            android:padding="16dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/cipher_input"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/edittext_border"
                android:gravity="top|start"
                android:hint="@string/paste_cipher_text_base64"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurface"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Key EditText -->
            <!-- Key field with toggle button inside -->
            <RelativeLayout
                android:id="@+id/key_input_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/edittext_border"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cipher_input">

                <EditText
                    android:id="@+id/key_input_text"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@null"
                    android:backgroundTint="@null"
                    android:hint="@string/enter_key"
                    android:inputType="textPassword"
                    android:paddingStart="12dp"
                    android:paddingEnd="48dp"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOnSurface" />

                <ImageButton
                    android:id="@+id/btn_toggle_key_input_visibility"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Toggle Key Visibility"
                    app:srcCompat="@drawable/baseline_visibility_off_24" />
            </RelativeLayout>

            <Button
                android:id="@+id/decrypt_text_button"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:background="@drawable/rounded_button"
                android:text="@string/decrypt"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.496"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/key_input_container" />

            <TextView
                android:id="@+id/plain_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/plain_text"
                android:textColor="?attr/colorOnBackground"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/decrypt_text_button" />

            <TextView
                android:id="@+id/plain_output"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/edittext_border_default"
                android:gravity="top|start"
                android:padding="12dp"
                android:text="@string/your_plain_output_will_appear_here"
                android:textColor="?attr/colorOnSurface"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/plain_label" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_private_text"
                android:layout_width="202dp"
                android:layout_height="53dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/rounded_button"
                android:text="@string/add_to_private"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                app:icon="@drawable/nav_private_folder"
                app:iconGravity="start"
                app:iconPadding="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/plain_output" />



        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>
</LinearLayout>
